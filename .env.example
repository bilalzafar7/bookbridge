# MongoDB Atlas — use Database → Connect → Drivers and append database path + query params.
# Example: mongodb+srv://USER:PASSWORD@cluster.mongodb.net/bookbridge?retryWrites=true&w=majority
MONGODB_URI=
# Database name (matches path segment in URI if present)
MONGODB_DB=bookbridge

# Generate: openssl rand -base64 32
AUTH_SECRET=

# App URL (production: your domain)
AUTH_URL=http://localhost:3000
